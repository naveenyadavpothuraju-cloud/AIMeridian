# AIMeridian Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (find in: Supabase > Project > Settings > Database)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
# Service role key — NEVER expose to frontend (find in: Supabase > Project > Settings > API)
SUPABASE_SERVICE_KEY=eyJ...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Claude API key (find in: console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Cron expression for fetch schedule (default: 6am and 6pm UTC daily)
FETCH_CRON=0 6,18 * * *

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS_RAW=http://localhost:3000,https://your-vercel-app.vercel.app

# ── Redis (Phase 5 only) ──────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
